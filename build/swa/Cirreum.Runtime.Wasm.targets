<Project>

	<PropertyGroup>
		<CirreumGenerateSwaConfig Condition="'$(CirreumGenerateSwaConfig)' == ''">true</CirreumGenerateSwaConfig>

		<!-- Resolve the deployment environment for CSP overlay selection.
		     Precedence:
		       1. $(CspEnvironmentName) — explicit escape hatch for unusual cases
		          (e.g. shared CSP across multiple ASPNETCORE_ENVIRONMENT values).
		       2. $(EnvironmentName)    — the standard ASP.NET Core / .NET SDK
		          property, set by pipelines via -p:EnvironmentName=Staging.
		       3. empty                 — no env overlay, just base + app policy.
		     Build configuration (Debug/Release) is intentionally NOT consulted —
		     a Release build can be deployed to any environment. -->
		<_CspEnv Condition="'$(CspEnvironmentName)' != ''">$(CspEnvironmentName)</_CspEnv>
		<_CspEnv Condition="'$(_CspEnv)' == ''">$(EnvironmentName)</_CspEnv>

		<!-- Policy file paths.
		     csp.base.policy : framework-shipped defaults (always loaded if any app policy exists)
		     csp.policy      : the app's primary policy (always loaded if present)
		     csp.{Env}.policy: optional deployment-environment overlay -->
		<CspBasePolicy Condition="'$(CspBasePolicy)' == ''">$(MSBuildThisFileDirectory)csp.base.policy</CspBasePolicy>
		<CspAppPolicy  Condition="'$(CspAppPolicy)'  == ''">$(MSBuildProjectDirectory)\Properties\csp.policy</CspAppPolicy>
		<CspEnvPolicy  Condition="'$(CspEnvPolicy)'  == '' And '$(_CspEnv)' != ''">$(MSBuildProjectDirectory)\Properties\csp.$(_CspEnv).policy</CspEnvPolicy>

		<!-- Use consuming app's template if it exists, otherwise fall back to package default -->
		<SwaConfigTemplate Condition="'$(SwaConfigTemplate)' == '' And Exists('$(MSBuildProjectDirectory)\wwwroot\staticwebapp.config.template.json')">$(MSBuildProjectDirectory)\wwwroot\staticwebapp.config.template.json</SwaConfigTemplate>
		<SwaConfigTemplate Condition="'$(SwaConfigTemplate)' == ''">$(MSBuildThisFileDirectory)staticwebapp.config.template.json</SwaConfigTemplate>

		<SwaCspGenerator Condition="'$(SwaCspGenerator)' == ''">$(MSBuildThisFileDirectory)SwaConfig-CspGen.ps1</SwaCspGenerator>

		<!-- Opt-in additional inline <script id="..."> elements to hash (comma/space separated).
		     The importmap script is always hashed; this is for any other inline scripts the
		     consuming app needs covered without having to fork the policy generator. -->
		<CspInlineScriptIds Condition="'$(CspInlineScriptIds)' == ''"></CspInlineScriptIds>

		<!-- PowerShell executable selection for cross-platform builds:
		     - Windows:    'powershell' (Windows PowerShell 5.1) — always present in System32.
		     - Linux/macOS: 'pwsh' (PowerShell 7+) — pre-installed on Microsoft-hosted
		                   Azure Pipelines Linux agents and standard in cross-platform CI.
		     The SwaConfig-CspGen.ps1 script is fully portable (only .NET BCL + cmdlets
		     that exist on both runtimes). '-ExecutionPolicy Bypass' is accepted by pwsh
		     as a harmless no-op on non-Windows platforms. -->
		<_CirreumPwshExecutable Condition="'$(OS)' == 'Windows_NT'">powershell</_CirreumPwshExecutable>
		<_CirreumPwshExecutable Condition="'$(OS)' != 'Windows_NT'">pwsh</_CirreumPwshExecutable>
	</PropertyGroup>

	<!-- Generate staticwebapp.config.json into the publish output. SWA only consumes
	     the published artifacts, so the source wwwroot is intentionally untouched
	     (avoids polluting source control / requiring .gitignore entries).
	     Always runs for Blazor WASM publish; if neither csp.policy nor csp.{Env}.policy
	     exists in the consuming app's Properties folder, the Content-Security-Policy
	     header is omitted from the generated config but the rest (routes, navigation
	     fallback, other security headers) is still emitted.
	     Inline-script hashes are computed from the published index.html, after the
	     Blazor SDK has populated the <script type="importmap"> body. -->
	<Target Name="GenerateStaticWebAppConfig"
			AfterTargets="Publish"
			Condition="'$(CirreumGenerateSwaConfig)' == 'true'
				And '$(UsingMicrosoftNETSdkBlazorWebAssembly)' == 'true'">

		<PropertyGroup>
			<_SwaPublishedIndexHtml>$(PublishDir)wwwroot\index.html</_SwaPublishedIndexHtml>
			<_SwaConfigOutput>$(PublishDir)wwwroot\staticwebapp.config.json</_SwaConfigOutput>
		</PropertyGroup>

		<Error Condition="!Exists('$(SwaCspGenerator)')" Text="[Cirreum] SwaCspGenerator not found: $(SwaCspGenerator)" />
		<Error Condition="!Exists('$(CspBasePolicy)')" Text="[Cirreum] CspBasePolicy not found: $(CspBasePolicy)" />
		<Error Condition="!Exists('$(SwaConfigTemplate)')" Text="[Cirreum] SwaConfigTemplate not found: $(SwaConfigTemplate)" />
		<Error Condition="!Exists('$(_SwaPublishedIndexHtml)')" Text="[Cirreum] Published index.html not found: $(_SwaPublishedIndexHtml). The Publish target must run before CSP generation." />

		<Message Importance="High" Text="[Cirreum] Generating staticwebapp.config.json (env: '$(_CspEnv)')" />
		<Message Importance="Normal" Text="[Cirreum] Template: $(SwaConfigTemplate)" />
		<Message Importance="Normal" Text="[Cirreum] Base policy: $(CspBasePolicy)" />
		<Message Importance="Normal" Text="[Cirreum] App policy: $(CspAppPolicy)" />
		<Message Importance="Normal" Condition="'$(CspEnvPolicy)' != ''" Text="[Cirreum] Env policy: $(CspEnvPolicy)" />
		<Message Importance="Normal" Text="[Cirreum] Published index.html: $(_SwaPublishedIndexHtml)" />
		<Message Importance="Normal" Text="[Cirreum] Output: $(_SwaConfigOutput)" />
		<Message Importance="Normal" Condition="'$(CspInlineScriptIds)' != ''" Text="[Cirreum] Additional inline script ids to hash: $(CspInlineScriptIds)" />

		<Exec Command='$(_CirreumPwshExecutable) -NoProfile -ExecutionPolicy Bypass -File "$(SwaCspGenerator)" -Template "$(SwaConfigTemplate)" -BasePolicy "$(CspBasePolicy)" -AppPolicy "$(CspAppPolicy)" -EnvPolicy "$(CspEnvPolicy)" -Output "$(_SwaConfigOutput)" -PublishedIndexHtml "$(_SwaPublishedIndexHtml)" -InlineScriptIds "$(CspInlineScriptIds)"' />
	</Target>

</Project>
