@namespace Cirreum.Components
@using Cirreum.Components.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@switch (_viewState) {

	case ViewState.Pending:
		@if (_hasAuthenticationRouting) {
			<AuthenticationStateInitializer />
		}
		<LayoutView Layout="@ResolvedPendingLayout" />
		break;

	case ViewState.AuthenticationPath:
		<AuthorizeRouteView RouteData="@RouteData" DefaultLayout="@ResolvedPendingLayout" />
		break;

	case ViewState.Ready:
		@if (_hasAuthenticationRouting) {
			<AuthorizeRouteView RouteData="@RouteData" DefaultLayout="@DefaultLayout">
				<NotAuthorized>
					@if (NotAuthorizedContent is not null) {
						@NotAuthorizedContent
					} else {
						<RedirectToLogin LoginPath="@LoginPath"
										 LoginHint="@LoginHint"
										 LoginPrompt="@LoginPrompt"
										 DomainHint="@DomainHint"
										 ReturnUrl="@_redirectReturnUrl" />
					}
				</NotAuthorized>
			</AuthorizeRouteView>
		} else {
			<RouteView RouteData="@RouteData" DefaultLayout="@DefaultLayout" />
		}
		break;

	case ViewState.RedirectToLogin:
		<LayoutView Layout="@ResolvedPendingLayout">
			<RedirectToLogin LoginPath="@LoginPath"
							 LoginHint="@LoginHint"
							 LoginPrompt="@LoginPrompt"
							 DomainHint="@DomainHint"
							 ReturnUrl="@_redirectReturnUrl" />
		</LayoutView>
		break;

	case ViewState.NotProvisioned:
		@if (NotProvisioned is not null) {
			@NotProvisioned
		} else {
			<LayoutView Layout="@ResolvedPendingLayout">
				<div class="container py-5">
					<div class="row justify-content-center">
						<div class="col-12 col-md-10 col-lg-8 col-xl-6">
							<div class="card shadow-sm border-warning">
								<div class="card-body p-4">
									<h1 class="h4 mb-3">Account Not Provisioned</h1>
									<div class="alert alert-warning mb-3" role="alert">
										Your identity was authenticated successfully, but no application account was found.
									</div>
									<p class="mb-0 text-body-secondary">
										Contact your administrator if you believe you should have access.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</LayoutView>
		}
		break;

	case ViewState.Disabled:
		@if (Disabled is not null) {
			@Disabled
		} else {
			<LayoutView Layout="@ResolvedPendingLayout">
				<div class="container py-5">
					<div class="row justify-content-center">
						<div class="col-12 col-md-10 col-lg-8 col-xl-6">
							<div class="card shadow-sm border-warning">
								<div class="card-body p-4">
									<h1 class="h4 mb-3">Account Disabled</h1>
									<div class="alert alert-warning mb-3" role="alert">
										Your account is currently disabled and cannot access this application.
									</div>
									<p class="mb-0 text-body-secondary">
										Contact your administrator for assistance.
									</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</LayoutView>
		}
		break;

}