@using Cirreum.Components

<HeadContent>
	<meta name="description" content="Cirreum Demo Client Application.">
	<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
	<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
	<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
	<link rel="manifest" href="/site.webmanifest">
	<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
	<meta name="apple-mobile-web-app-title" content="Cirreum Demo Client">
	<meta name="application-name" content="Cirreum Demo Client">
	<meta name="msapplication-TileColor" content="#2d89ef">
</HeadContent>

<Router AppAssembly="@typeof(App).Assembly">
	<Found Context="routeData">
		<AppRouteView RouteData="@routeData"
					  DefaultLayout="@typeof(MinimalLayout)"
					  PendingLayout="@typeof(AuthenticationLayout)">
			<NotAuthorizedContent>
				<RedirectToUnauthorized UnauthorizedPage="/unauthorized" />
			</NotAuthorizedContent>
		</AppRouteView>
	</Found>
	<NotFound>
		<LayoutView Layout="@typeof(MinimalLayout)">
			<Custom404 />
		</LayoutView>
	</NotFound>
</Router>

<DialogContainer DefaultOptions="@(DialogOptions.Default)" />
<MenuContainer />
<ToastContainer ToastType="ToastStyleType.Primary"
				ShowProgressBar="true"
				PauseProgressOnHover="true" />
<TooltipContainer />
